{
  "rewrites": [
    { "source": "/yingxiao/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/yingxiao/api/(.*)", "destination": "/api/$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/yingxiao/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
